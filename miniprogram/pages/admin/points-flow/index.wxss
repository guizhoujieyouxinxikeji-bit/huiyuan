.tabs-scroll { white-space: nowrap; }
.tabs-row { display: flex; gap: 12rpx; padding: 16rpx 24rpx; }
.tab-btn { display: inline-block; padding: 12rpx 20rpx; border-radius: 24rpx; font-size: 22rpx; color: #888; background: #1A1A1A; white-space: nowrap; }
.tab-btn.active { background: rgba(212,168,67,0.15); color: #D4A843; font-weight: 600; }
.summary-bar { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 24rpx; }
.flow-card { padding: 20rpx 28rpx; }
.flow-row1 { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.flow-name { font-size: 26rpx; color: #ddd; }
.type-badge { font-size: 20rpx; padding: 4rpx 14rpx; border-radius: 12rpx; }
.flow-row2 { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6rpx; }
.flow-desc { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.flow-points { font-size: 30rpx; font-weight: 700; flex-shrink: 0; margin-left: 16rpx; }
.flow-points.positive { color: #2ECC71; }
.flow-points.negative { color: #E74C3C; }
.flow-row3 { margin-top: 2rpx; }
