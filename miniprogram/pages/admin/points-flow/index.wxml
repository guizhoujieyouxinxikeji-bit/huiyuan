<nav-bar title="积分流水" back="{{true}}" />
<view class="container">
  <scroll-view scroll-x class="tabs-scroll">
    <view class="tabs-row">
      <view wx:for="{{tabs}}" wx:key="key" class="tab-btn {{activeTab === item.key ? 'active' : ''}}" bind:tap="switchTab" data-key="{{item.key}}">{{item.name}}</view>
    </view>
  </scroll-view>

  <view class="summary-bar card">
    <text class="text-muted text-sm">共 {{flows.length}} 条</text>
    <view class="text-gold text-sm" bind:tap="exportData">导出 ↓</view>
  </view>

  <block wx:if="{{flows.length > 0}}">
    <view wx:for="{{flows}}" wx:key="id" class="flow-card card">
      <view class="flow-row1">
        <text class="flow-name">{{item.memberName}} <text class="text-muted text-xs">{{item.memberPhone}}</text></text>
        <view class="type-badge" style="background:{{item.typeColor}}20;color:{{item.typeColor}};">{{item.typeLabel}}</view>
      </view>
      <view class="flow-row2">
        <text class="flow-desc text-sm text-muted">{{item.description || item.typeLabel}}</text>
        <text class="flow-points {{item.isPositive ? 'positive' : 'negative'}}">{{item.pointsStr}}</text>
      </view>
      <view class="flow-row3 text-muted text-xs">{{item.dateStr}} · 余额 {{item.balanceAfter}}</view>
    </view>
  </block>
  <empty-state wx:else text="暂无积分流水" icon="⭐" />
  <load-more status="{{loadStatus}}" />
</view>
