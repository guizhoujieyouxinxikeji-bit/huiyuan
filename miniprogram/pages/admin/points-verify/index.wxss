.today-bar { border-radius: 12rpx; }
.form-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 1000; display: flex; align-items: center; justify-content: center; }
.form-card { width: 90%; background: #1A1A1A; border-radius: 24rpx; padding: 40rpx 32rpx; border: 1rpx solid rgba(212,168,67,0.2); }
.form-title { font-size: 32rpx; font-weight: 600; color: #D4A843; margin-bottom: 32rpx; text-align: center; }
.form-group { margin-bottom: 24rpx; }
.form-label { font-size: 24rpx; color: #B0B0B0; margin-bottom: 8rpx; display: block; }
.form-input { background: #242424; border: 1rpx solid rgba(212,168,67,0.15); border-radius: 12rpx; padding: 18rpx 20rpx; color: #fff; font-size: 28rpx; }
.phone-row { display: flex; gap: 12rpx; align-items: center; }
.scan-btn { padding: 14rpx 20rpx; background: rgba(212,168,67,0.1); border-radius: 12rpx; font-size: 24rpx; color: #D4A843; white-space: nowrap; }
.form-btns { display: flex; gap: 16rpx; margin-top: 32rpx; }
.verify-card { padding: 20rpx 28rpx; }
.v-row1 { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6rpx; }
.v-name { font-size: 26rpx; color: #ddd; }
.v-points { font-size: 30rpx; font-weight: 700; color: #E74C3C; }
.v-items { margin-bottom: 4rpx; }
.v-row2 { margin-top: 2rpx; }
