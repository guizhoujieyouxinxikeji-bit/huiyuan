.date-filter { display: flex; align-items: center; padding: 16rpx 24rpx; gap: 16rpx; }
.date-pick { padding: 12rpx 20rpx; background: #1A1A1A; border-radius: 8rpx; font-size: 24rpx; color: #B0B0B0; border: 1rpx solid rgba(212,168,67,0.15); min-width: 180rpx; text-align: center; }
.date-sep { color: #666; font-size: 24rpx; }
.summary-bar { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 24rpx; }
.consume-card { padding: 20rpx 28rpx; }
.row1 { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.name { font-size: 26rpx; color: #ddd; }
.amount { font-size: 32rpx; font-weight: 700; }
.row2 { display: flex; gap: 16rpx; align-items: center; margin-bottom: 6rpx; }
.points-info { font-size: 22rpx; color: #E74C3C; background: rgba(231,76,60,0.1); padding: 2rpx 10rpx; border-radius: 6rpx; }
.row3, .row4 { margin-top: 4rpx; }
