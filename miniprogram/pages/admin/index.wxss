.stat-grid { display: flex; flex-wrap: wrap; padding: 0 12rpx; }
.stat-card { width: calc(50% - 24rpx); margin: 8rpx 12rpx; text-align: center; padding: 28rpx 16rpx; }
.stat-num { font-size: 36rpx; font-weight: 700; color: #D4AF37; font-family: 'DIN Alternate',sans-serif; }
.stat-label { font-size: 22rpx; color: #888; margin-top: 4rpx; }
.cumulative-row { display: flex; padding: 24rpx 0; }
.cum-item { flex: 1; text-align: center; }
.cum-val { display: block; font-size: 32rpx; font-weight: 700; color: #D4AF37; }
.cum-label { display: block; font-size: 20rpx; margin-top: 4rpx; }
.menu-grid { display: flex; flex-wrap: wrap; padding: 0 12rpx; }
.menu-item { width: 33.33%; text-align: center; padding: 24rpx 0; }
.menu-icon { display: block; font-size: 44rpx; margin-bottom: 8rpx; }
.menu-name { font-size: 24rpx; color: #B0B0B0; }