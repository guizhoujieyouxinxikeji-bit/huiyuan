<nav-bar title="会员管理" back="{{true}}" />
<view class="container">
  <view class="search-bar card">
    <input class="search-input" placeholder="搜索手机号/姓名" value="{{keyword}}" bindinput="onInputChange" bindconfirm="onSearch" />
    <view class="search-btn" bind:tap="onSearch">🔍</view>
  </view>
  <view class="count-row text-muted text-sm" style="padding:8rpx 32rpx;">共 {{members.length}} 位会员</view>

  <block wx:if="{{members.length > 0}}">
    <view wx:for="{{members}}" wx:key="id" class="member-item card" bind:tap="viewDetail" data-item="{{item}}">
      <view class="member-left">
        <view class="member-avatar">{{item.nickname ? item.nickname[0] : '?'}}</view>
        <view class="member-info">
          <view class="flex items-center" style="gap:12rpx;">
            <text class="member-name">{{item.nickname}}</text>
            <text class="level-tag">{{item.levelInfo.name}}</text>
          </view>
          <view class="member-phone text-muted text-xs">{{item.phoneMasked}} · {{item.dateStr}}</view>
        </view>
      </view>
      <view class="member-stats text-right">
        <view class="text-gold text-sm">¥{{item.totalRecharge || 0}}</view>
        <view class="text-muted text-xs">{{item.pointsBalance || 0}}积分</view>
      </view>
    </view>
  </block>
  <empty-state wx:else text="暂无会员" icon="👥" />
  <load-more status="{{loadStatus}}" />

  <!-- Detail Modal -->
  <view wx:if="{{showDetail}}" class="modal-overlay" bind:tap="closeDetail">
    <view class="modal-content" catchtap="">
      <view class="modal-header">
        <text class="modal-title">会员详情</text>
        <text class="modal-close" bind:tap="closeDetail">✕</text>
      </view>
      <view class="detail-body" wx:if="{{selectedMember}}">
        <view class="detail-row"><text class="detail-label">姓名</text><text>{{selectedMember.nickname}}</text></view>
        <view class="detail-row"><text class="detail-label">手机号</text><text>{{selectedMember.phone}}</text></view>
        <view class="detail-row"><text class="detail-label">等级</text><text class="text-gold">{{selectedMember.levelInfo.name}}</text></view>
        <view class="detail-row"><text class="detail-label">注册时间</text><text>{{selectedMember.dateStr}}</text></view>
        <view class="detail-row"><text class="detail-label">累计充值</text><text class="text-gold">¥{{selectedMember.totalRecharge}}</text></view>
        <view class="detail-row"><text class="detail-label">累计消费</text><text>¥{{selectedMember.totalConsume || 0}}</text></view>
        <view class="detail-row"><text class="detail-label">当前积分</text><text>{{selectedMember.pointsBalance}}</text></view>
        <view class="detail-row"><text class="detail-label">账户余额</text><text>¥{{selectedMember.balance || 0}}</text></view>
        <view class="detail-row"><text class="detail-label">推荐码</text><text>{{selectedMember.referralCode || '-'}}</text></view>
        <view class="detail-row"><text class="detail-label">推荐人</text><text>{{selectedMember.referrerName || '无'}}</text></view>
        <view class="detail-row"><text class="detail-label">推荐人数</text><text>{{selectedMember.referralCount || 0}}</text></view>
      </view>
    </view>
  </view>
</view>