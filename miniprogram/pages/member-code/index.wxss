.code-page { padding: 24rpx; min-height: 100vh; display: flex; flex-direction: column; align-items: center; }
.code-card { width: 100%; background: linear-gradient(145deg, #242424, #1A1A1A); border-radius: 24rpx; padding: 48rpx 32rpx; text-align: center; border: 1rpx solid rgba(212,168,67,0.25); box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.4); }
.brand-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32rpx; padding: 0 8rpx; }
.brand-name { font-size: 32rpx; font-weight: 700; color: #D4A843; }
.brand-level { font-size: 22rpx; color: #B0B0B0; background: rgba(212,168,67,0.1); padding: 4rpx 16rpx; border-radius: 12rpx; }
.qr-wrapper { width: 400rpx; height: 400rpx; margin: 0 auto 24rpx; background: #fff; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.2); }
.qr-canvas { width: 200px; height: 200px; }
.code-number { font-size: 36rpx; font-weight: 700; color: #D4A843; letter-spacing: 4rpx; font-family: 'DIN Alternate',monospace; margin-bottom: 8rpx; }
.code-hint { font-size: 24rpx; color: #888; }
.refresh-btn { margin-top: 32rpx; padding: 20rpx 48rpx; border: 1rpx solid rgba(212,168,67,0.4); border-radius: 40rpx; color: #D4A843; font-size: 28rpx; }
.tips-section { width: 100%; margin-top: 40rpx; }
.tips-title { font-size: 28rpx; color: #B0B0B0; margin-bottom: 16rpx; font-weight: 600; }
.tips-item { font-size: 24rpx; color: #666; line-height: 2; }