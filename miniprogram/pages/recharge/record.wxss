.summary-row { display: flex; padding: 28rpx 0; }
.summary-item { flex: 1; text-align: center; }
.summary-val { display: block; font-size: 36rpx; font-weight: 700; font-family: 'DIN Alternate',sans-serif; }
.summary-label { font-size: 22rpx; color: #888; margin-top: 4rpx; display: block; }
.record-item { padding: 24rpx 28rpx; margin-bottom: 0; }
.record-item + .record-item { margin-top: -8rpx; }
.record-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.record-date { font-size: 24rpx; color: #888; }
.status-badge { font-size: 20rpx; padding: 4rpx 16rpx; border-radius: 16rpx; }
.status-success { background: rgba(46,204,113,0.15); color: #2ECC71; }
.status-pending { background: rgba(212,168,67,0.15); color: #D4A843; }
.status-refunded { background: rgba(231,76,60,0.15); color: #E74C3C; }
.status-failed { background: rgba(128,128,128,0.15); color: #888; }
.record-bottom { display: flex; align-items: baseline; gap: 16rpx; }
.record-amount { font-size: 36rpx; font-weight: 700; color: #D4AF37; }
.record-bonus { font-size: 24rpx; color: #2ECC71; }
