.balance-card { text-align: center; padding: 40rpx; }
.balance-label { font-size: 26rpx; color: #B0B0B0; }
.balance-value { font-size: 56rpx; font-weight: 700; color: #D4AF37; font-family: 'DIN Alternate',sans-serif; margin-top: 8rpx; }
.pkg-grid { display: flex; flex-wrap: wrap; padding: 0 12rpx; gap: 16rpx; }
.pkg-item { width: calc(50% - 24rpx); background: #242424; border-radius: 16rpx; padding: 32rpx 20rpx; text-align: center; border: 2rpx solid transparent; position: relative; overflow: hidden; margin: 0 4rpx; }
.pkg-item.selected { border-color: #D4A843; box-shadow: 0 0 20rpx rgba(212,168,67,0.2); }
.pkg-tag { position: absolute; top: 0; right: 0; background: linear-gradient(135deg, #D4A843, #B8912E); color: #000; font-size: 18rpx; padding: 4rpx 16rpx; border-radius: 0 14rpx 0 12rpx; font-weight: 600; }
.pkg-amount { font-size: 40rpx; font-weight: 700; color: #D4AF37; }
.pkg-bonus { font-size: 22rpx; color: #2ECC71; margin-top: 8rpx; }
.custom-section { margin: 0 24rpx; }
.custom-input-row { display: flex; align-items: center; }
.custom-prefix { font-size: 40rpx; color: #D4A843; font-weight: 700; margin-right: 12rpx; }
.custom-input { flex: 1; font-size: 36rpx; color: #fff; padding: 12rpx 0; border-bottom: 1rpx solid rgba(212,168,67,0.3); }
.custom-bonus { font-size: 24rpx; color: #2ECC71; margin-top: 16rpx; }
.agreement-row { display: flex; align-items: center; padding: 24rpx 32rpx; }
.checkbox { width: 36rpx; height: 36rpx; border: 2rpx solid #555; border-radius: 6rpx; display: flex; align-items: center; justify-content: center; font-size: 22rpx; color: transparent; margin-right: 12rpx; }
.checkbox.checked { border-color: #D4A843; color: #D4A843; background: rgba(212,168,67,0.1); }
.agreement-text { font-size: 24rpx; color: #999; }
.submit-btn { margin: 16rpx 24rpx; }
.rules-card { margin: 32rpx 24rpx; }
.rules-title { font-size: 26rpx; color: #B0B0B0; margin-bottom: 12rpx; font-weight: 600; }
.rules-text { font-size: 22rpx; color: #666; line-height: 2; }
