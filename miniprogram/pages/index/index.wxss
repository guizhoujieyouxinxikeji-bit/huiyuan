.container { padding-bottom: 40rpx; }
.hero-card { margin: 24rpx; border-radius: 24rpx; overflow: hidden; position: relative; }
.hero-bg { position: absolute; inset: 0; background: linear-gradient(145deg, #2A2A2A, #1A1A1A); }
.hero-bg::after { content: ''; position: absolute; inset: 0; border-radius: 24rpx; border: 1rpx solid rgba(212,168,67,0.25); pointer-events: none; }
.hero-content { position: relative; padding: 48rpx 40rpx; }
.level-row { margin-bottom: 16rpx; }
.level-badge { display: inline-block; padding: 8rpx 24rpx; border-radius: 24rpx; font-size: 22rpx; font-weight: 600; }
.level-badge.bronze { background: rgba(205,127,50,0.15); color: #CD7F32; }
.level-badge.silver { background: rgba(192,192,192,0.15); color: #C0C0C0; }
.level-badge.gold { background: rgba(212,168,67,0.15); color: #D4A843; }
.level-badge.diamond { background: rgba(185,242,255,0.15); color: #B9F2FF; }
.member-name { font-size: 40rpx; font-weight: 700; color: #fff; margin-bottom: 4rpx; }
.member-phone { margin-bottom: 32rpx; }
.hero-stats { display: flex; align-items: center; background: rgba(0,0,0,0.3); border-radius: 16rpx; padding: 28rpx 0; }
.stat-item { flex: 1; text-align: center; }
.stat-value { font-size: 40rpx; font-weight: 700; color: #D4AF37; font-family: 'DIN Alternate','Avenir',sans-serif; }
.stat-label { font-size: 22rpx; color: #888; margin-top: 4rpx; }
.stat-divider { width: 1rpx; height: 60rpx; background: rgba(255,255,255,0.1); }
.action-grid { display: flex; flex-wrap: wrap; padding: 0 12rpx; }
.action-item { width: 25%; text-align: center; padding: 20rpx 0; }
.action-icon { width: 88rpx; height: 88rpx; margin: 0 auto 12rpx; background: #242424; border-radius: 20rpx; display: flex; align-items: center; justify-content: center; font-size: 40rpx; border: 1rpx solid rgba(212,168,67,0.1); }
.action-name { font-size: 24rpx; color: #B0B0B0; }
.activity-card { padding: 0; }
.activity-item { display: flex; align-items: center; padding: 24rpx 32rpx; border-bottom: 1rpx solid rgba(255,255,255,0.04); }
.activity-item:last-child { border-bottom: none; }
.activity-dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: #D4A843; margin-right: 20rpx; flex-shrink: 0; }
.activity-content { flex: 1; }
.activity-desc { font-size: 26rpx; color: #ddd; }
.activity-time { margin-top: 4rpx; }
.activity-points { font-size: 28rpx; font-weight: 600; flex-shrink: 0; margin-left: 16rpx; }
.activity-points.positive { color: #2ECC71; }
.activity-points.negative { color: #E74C3C; }