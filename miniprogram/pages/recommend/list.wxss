.stats-row { display: flex; padding: 28rpx 0; }
.stat-col { flex: 1; text-align: center; }
.stat-num { display: block; font-size: 40rpx; font-weight: 700; font-family: 'DIN Alternate',sans-serif; }
.stat-label { display: block; font-size: 22rpx; margin-top: 4rpx; }
.ref-item { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 28rpx; }
.ref-left { display: flex; align-items: center; }
.ref-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; background: #2A2A2A; display: flex; align-items: center; justify-content: center; font-size: 28rpx; color: #D4A843; margin-right: 20rpx; border: 2rpx solid rgba(212,168,67,0.2); }
.ref-name { font-size: 28rpx; color: #ddd; }
.ref-phone { margin-top: 4rpx; }
.ref-right { text-align: right; }
.ref-reward { font-size: 32rpx; font-weight: 700; }
.ref-reward-label { margin-top: 2rpx; }
