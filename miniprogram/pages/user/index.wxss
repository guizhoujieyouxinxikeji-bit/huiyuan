.profile-header { text-align: center; padding: 48rpx 24rpx 32rpx; }
.avatar-ring { width: 140rpx; height: 140rpx; border-radius: 50%; background: linear-gradient(135deg, #D4A843, #B8912E); padding: 4rpx; margin: 0 auto 20rpx; display: inline-flex; }
.avatar { width: 100%; height: 100%; border-radius: 50%; background: #242424; display: flex; align-items: center; justify-content: center; font-size: 48rpx; color: #D4A843; }
.profile-name { font-size: 36rpx; font-weight: 700; color: #fff; }
.level-tag { display: inline-block; margin-top: 8rpx; padding: 4rpx 20rpx; border-radius: 16rpx; font-size: 22rpx; }
.level-tag.bronze { background: rgba(205,127,50,0.15); color: #CD7F32; }
.level-tag.silver { background: rgba(192,192,192,0.15); color: #C0C0C0; }
.level-tag.gold { background: rgba(212,168,67,0.15); color: #D4A843; }
.level-tag.diamond { background: rgba(185,242,255,0.15); color: #B9F2FF; }
.profile-phone { margin-top: 8rpx; }
.stats-row { display: flex; padding: 32rpx 0; }
.stat-col { flex: 1; text-align: center; }
.stat-num { font-size: 36rpx; font-weight: 700; color: #D4AF37; font-family: 'DIN Alternate',sans-serif; }
.stat-text { font-size: 22rpx; color: #888; margin-top: 4rpx; }
.admin-entry { display: flex; align-items: center; justify-content: space-between; border: 1rpx solid rgba(212,168,67,0.3) !important; }
.admin-icon { font-size: 36rpx; margin-right: 16rpx; }
.admin-text { font-size: 30rpx; color: #D4A843; font-weight: 600; }
.admin-arrow { font-size: 36rpx; color: #D4A843; }
.menu-group { margin-top: 16rpx; }
.menu-group-title { padding: 16rpx 40rpx; font-size: 24rpx; color: #888; }
.menu-card { padding: 0 !important; }
.menu-item { display: flex; align-items: center; justify-content: space-between; padding: 30rpx 32rpx; border-bottom: 1rpx solid rgba(255,255,255,0.04); }
.menu-item:last-child { border-bottom: none; }
.menu-left { display: flex; align-items: center; }
.menu-icon { font-size: 36rpx; margin-right: 20rpx; }
.menu-name { font-size: 28rpx; color: #ddd; }
.menu-arrow { font-size: 32rpx; color: #555; }
.logout-btn { margin: 48rpx 24rpx; }