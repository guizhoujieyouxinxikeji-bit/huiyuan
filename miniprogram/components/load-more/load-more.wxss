.load-more { display: flex; align-items: center; justify-content: center; padding: 32rpx; gap: 16rpx; }
.load-text { font-size: 24rpx; color: #666; }
.spinner { width: 32rpx; height: 32rpx; border: 3rpx solid #444; border-top-color: #D4A843; border-radius: 50%; animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
.nomore .line { width: 60rpx; height: 1rpx; background: linear-gradient(90deg, transparent, #444, transparent); }
